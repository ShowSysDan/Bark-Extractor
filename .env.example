# Bark Extractor – Environment Configuration
# Copy this file to .env and edit as needed.

# Flask
FLASK_ENV=development
FLASK_DEBUG=false

# Server
PORT=5100

# Paths
# Where to store downloaded MP3s (default: ./downloads)
DOWNLOADS_DIR=./downloads

# Where Flask session files are stored (default: ./sessions)
SESSIONS_DIR=./sessions

# Path to the ffmpeg binary
# Linux (apt):  /usr/bin/ffmpeg
# macOS (brew): /usr/local/bin/ffmpeg  or  /opt/homebrew/bin/ffmpeg
# Windows:      C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_PATH=ffmpeg

# Path to yt-dlp binary/script
# If installed via pip into the venv, 'yt-dlp' (no path) is usually correct.
# Windows pip venv: .venv\Scripts\yt-dlp.exe
YTDLP_PATH=yt-dlp

# Secret key for Flask sessions (auto-generated random value is fine for dev)
# For production, set a long random string here and keep it secret.
# SECRET_KEY=change-me-to-a-long-random-string
